def main():
    if not os.path.exists(os.path.expanduser(DB_PATH)):
        print(f"DB not found: {DB_PATH}", file=sys.stderr)
        print("Run 'npm run tauri dev' once to create the DB, then close the app and re-run.", file=sys.stderr)
        sys.exit(1)

    print(f"{'[DRY RUN] ' if DRY else ''}Importing to: {DB_PATH}")
    print(f"  {len(CTX_CARDS)} Context Cards")
    print(f"  {len(WORK_ITEMS)} Work Items")
    generated_handoffs = sum(1 for row in WORK_ITEMS if row[4] == "done" and row[0] not in {h["wi"].split(" ", 1)[0] for h in HANDOFFS})
    print(f"  {len(HANDOFFS) + generated_handoffs} Handoff Notes ({len(HANDOFFS)} explicit, {generated_handoffs} generated from completed WIs)")
    print(f"  {len(EVIDENCE)} Evidence entries")
    print(f"  {len(EVENTS)} Events")
    print(f"  {len(GATE_RULES)} Gate Rules")
    print(f"  {len(AGENT_PROFILES)} Agent Profiles")

    if DRY:
        return

    con = sqlite3.connect(os.path.expanduser(DB_PATH))
    cur = con.cursor()

    cur.executescript("""
        CREATE TABLE IF NOT EXISTS privileged_operation_requests (
            id TEXT PRIMARY KEY NOT NULL,
            agent_id TEXT NOT NULL DEFAULT '', operation TEXT NOT NULL DEFAULT '',
            args_json TEXT NOT NULL DEFAULT '{}', decision TEXT NOT NULL DEFAULT 'deny',
            reason TEXT NOT NULL DEFAULT '', created_at TEXT NOT NULL DEFAULT (datetime('now'))
        );
        CREATE INDEX IF NOT EXISTS idx_privileged_operation_created
            ON privileged_operation_requests(created_at);
    """)

    for c in CTX_CARDS:
        cur.execute("""
            INSERT OR REPLACE INTO context_cards
              (id, title, question, purpose, context, constraint_text, past,
               related_wi_json, related_ev_json, unresolved_json, next_policy,
               card_type, customer_company, customer_contact, customer_email,
               customer_phone, customer_relationship,
               created_at, updated_at)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        """, (
            c["id"], c["title"], c["question"], c["purpose"], c["context"],
            c["constraint_text"], c["past"],
            c["related_wi_json"], c["related_ev_json"], c["unresolved_json"],
            c["next_policy"],
            c.get("card_type", "general"),
            c.get("customer_company", ""),
            c.get("customer_contact", ""),
            c.get("customer_email", ""),
            c.get("customer_phone", ""),
            c.get("customer_relationship", ""),
            c["created_at"], NOW,
        ))

    for row in WORK_ITEMS:
        cur.execute("""
            INSERT OR REPLACE INTO work_items
              (id, title, domain, assignee, col, status, risk, context_id,
               next_action, gate, rde, morning, bounced, gate_perm, gate_stops,
               ctx_json, ho_json, ev_json, rde_audit_json,
               agent_picked_up_at, agent_escalated, escalation_reason,
               github_links_json,
               audit_required, reviewer, deviation_risk, drift_note,
               source, source_ref, project,
               created_at, updated_at)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        """, row)

    # Set project labels
    cur.execute("UPDATE work_items SET project='Kazane' WHERE project='' AND id NOT LIKE 'WI-BAO-%'")
    cur.execute("UPDATE work_items SET project='AI番頭' WHERE project='' AND id LIKE 'WI-BAO-%'")

    for h in HANDOFFS:
        cur.execute("""
            INSERT OR REPLACE INTO handoff_notes
              (id, wi, assignee, domain, did, judged, couldnt, uncertain,
               bounce, next, upd_ctx, ev_json, gate, ask,
               escalated, escalation_reason, created_at)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        """, (
            h["id"], h["wi"], h["assignee"], h["domain"],
            h["did"], h["judged"], h["couldnt"], h["uncertain"],
            h["bounce"], h["next"], h["upd_ctx"], h["ev_json"],
            h["gate"], h["ask"], h["escalated"], h["escalation_reason"],
            h["created_at"],
        ))

    # Every completed Work Item must retain an explicit Handoff Note after reset.
    explicit_handoff_wis = {h["wi"].split(" ", 1)[0] for h in HANDOFFS}
    for row in WORK_ITEMS:
        wi_id, title, domain, assignee, col = row[0], row[1], row[2], row[3], row[4]
        if col != "done" or wi_id in explicit_handoff_wis:
            continue
        ho = json.loads(row[16])
        cur.execute("""
            INSERT OR REPLACE INTO handoff_notes
              (id, wi, assignee, domain, did, judged, couldnt, uncertain,
               bounce, next, upd_ctx, ev_json, gate, ask,
               escalated, escalation_reason, created_at)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        """, (
            f"HO-SEED-{wi_id}", f"{wi_id} {title}", assignee, domain,
            ho.get("did", "完了。"), ho.get("judged", "完了条件を満たした。"),
            ho.get("couldnt", ""), ho.get("uncertain", ""), ho.get("bounce", ""),
            ho.get("next", "完了・記録済"), ho.get("updCtx", ""),
            json.dumps(ho.get("ev", []), ensure_ascii=False), ho.get("gate", ""),
            ho.get("ask", ""), 0, "", row[30],
        ))

    for e in EVIDENCE:
        cur.execute("""
            INSERT OR REPLACE INTO evidence_log
              (id, type, label, trust, store, wi_id, ho_id, ctx_id, note, created_at)
            VALUES (?,?,?,?,?,?,?,?,?,?)
        """, (
            e["id"], e["type"], e["label"], e["trust"], e["store"],
            e["wi_id"], e["ho_id"], e["ctx_id"], e["note"], e["created_at"],
        ))

    for e in EVENTS:
        cur.execute("""
            INSERT OR IGNORE INTO events
              (id, wi_id, event_type, from_col, to_col, actor, note, created_at)
            VALUES (?,?,?,?,?,?,?,?)
        """, (
            e["id"], e["wi_id"], e["event_type"], e["from_col"],
            e["to_col"], e["actor"], e["note"], e["created_at"],
        ))

    for g in GATE_RULES:
        cur.execute("""
            INSERT OR REPLACE INTO gate_rules (domain, perm_json, stops_json)
            VALUES (?,?,?)
        """, (g["domain"], json.dumps(g["perm"], ensure_ascii=False), json.dumps(g["stops"], ensure_ascii=False)))

    for a in AGENT_PROFILES:
        cur.execute("""
            INSERT OR REPLACE INTO agent_profiles
              (id, name, model, trust_level, capabilities_json, gate_perm, gate_stops)
            VALUES (?,?,?,?,?,?,?)
        """, (a["id"], a["name"], a["model"], a["trust_level"],
              a["capabilities_json"], a["gate_perm"], a["gate_stops"]))

    for u in USERS:
        cur.execute("""
            INSERT OR REPLACE INTO users (id, name, email, role, enabled, created_at)
            VALUES (?,?,?,?,?,?)
        """, (u["id"], u["name"], u["email"], u["role"], u["enabled"], u["created_at"]))

    con.commit()
    con.close()
    print("Done. Open Kazane to verify.")


if __name__ == "__main__":
    main()
