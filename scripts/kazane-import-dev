#!/usr/bin/env python3
"""
kazane-import-dev
Injects the full Kazane development task state into the local SQLite DB.
Run with the app CLOSED to avoid write conflicts.

Usage:
  scripts/kazane-import-dev          # import into default DB path
  scripts/kazane-import-dev --dry-run  # show counts without writing
"""

import sqlite3, json, os, sys
from datetime import datetime, timezone

DB_PATH = os.path.expanduser(
    "~/Library/Application Support/jp.zyxcorp.kazane/kazane.db"
)
NOW = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S")
DRY = "--dry-run" in sys.argv


def j(obj):
    return json.dumps(obj, ensure_ascii=False)


