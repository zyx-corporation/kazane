COL_STATUS = {
    "inbox": "Inbox", "ai": "AI Working", "human": "Needs Human",
    "gate": "Expert / Gate", "done": "Done / Logged",
}

def wi_row(id, title, domain, assignee, col, risk, ctx_id, next_action, gate,
           rde, morning, bounced, gate_perm, gate_stops, ctx, ho, ev,
           rde_audit=None, github_links=None, created_at=NOW,
           audit_required=False, reviewer="", deviation_risk="low", drift_note="",
           source="manual", source_ref="", project=""):
    return (
        id, title, domain, assignee, col, COL_STATUS[col], risk, ctx_id,
        next_action, gate,
        1 if rde else 0, 1 if morning else 0, 1 if bounced else 0,
        gate_perm, gate_stops,
        j(ctx), j(ho), j(ev),
        j(rde_audit) if rde_audit else None,
        None, 0, "",
        j(github_links) if github_links else "[]",
        1 if audit_required else 0, reviewer, deviation_risk, drift_note,
        source, source_ref, project,
        created_at, created_at,
    )

def v09_row(id, title, priority, depends, deliverable, evidence,
            assignee="Claude Code", risk="中", gate="AI権限内で設計・実装可",
            col="inbox", did="未着手。v0.9 roadmapで計画済み。",
            uncertain=None, next_action=None):
    dependency = "、".join(depends) if depends else "なし"
    return wi_row(
        id, f"v0.9: {title}", "開発", assignee, col, risk, "CTX-V09",
        next_action or ("完了・記録済" if col == "done" else deliverable),
        gate, False, priority == "P0" and col != "done", False,
        "調査・設計・実装・ローカル検証・文書化",
        "外部公開／本番反映／資格情報／責任境界の最終承認",
        ctx={
            "question": f"{title}を、検証可能なProduct Candidate要件として成立させられるか。",
            "purpose": deliverable,
            "constraint": f"優先度 {priority}。依存: {dependency}。ローカルファーストと既存Gateを維持する。",
            "unresolved": evidence,
        },
        ho={
            "did": did,
            "uncertain": uncertain or evidence,
            "bounce": "依存未完了または人間判断境界では停止する。",
            "next": next_action or ("完了・記録済" if col == "done" else deliverable),
        },
        ev=[], created_at="2026-07-13T09:00:00", project="Kazane",
    )

