#!/usr/bin/env bash
# kazane-agent — Agent CLI for Kazane Work OS (v0.8 hibiki)
#
# Reads Work Items from the Kazane task queue and writes back Handoff Notes.
# Kazane polls the handoffs directory every 10s and auto-imports results.
#
# Usage:
#   kazane-agent list                           — list pending tasks (shows lock status)
#   kazane-agent pickup [--agent-id <id>]       — print task JSON and acquire lock
#   kazane-agent status                         — project overview (all items by column)
#   kazane-agent read <WI-ID>                   — print full Work Item as JSON
#   kazane-agent create --title <title> [opts]  — create a new Work Item in SQLite
#   kazane-agent update <WI-ID> [opts]          — patch fields on an existing Work Item
#   kazane-agent report-test --tool <tool> [opts] — record test result as Evidence Log entry
#   kazane-agent submit <WI-ID> [opts]          — submit a completed handoff
#   kazane-agent submit <WI-ID> --escalate "reason" — submit with escalation
#   kazane-agent submit <WI-ID> --next-agent <id>   — route WI to another agent after submit
#   kazane-agent watch [--timeout <secs>]       — wait for new task (exits 0 when task arrives)
#   kazane-agent lock <WI-ID>                   — manually acquire processing lock
#   kazane-agent unlock <WI-ID>                 — release processing lock
#   kazane-agent auto                           — auto-process all pending tasks (demo)
#   kazane-agent dirs                           — print task/handoff directory paths
#   kazane-agent mail-import [opts]             — import a Gmail thread as a Work Item
#   kazane-agent calendar-import [opts]         — import a calendar event as a Work Item
#   kazane-agent sync-github-issues [opts]       — sync all open/closed GitHub Issues into Work Items
#   kazane-agent banto-demo                     — print AI番頭 demo flow guide
#
# create options:
#   --title <text>       Work item title (required)
#   --domain <text>      Domain (default: 開発)
#   --assignee <text>    Assignee (default: Claude Code)
#   --ctx <CTX-ID>       Context Card ID (default: —)
#   --risk 低|中|高       Risk level (default: 中)
#   --next <text>        Next action text
#   --agent-id <id>      Acting agent profile ID (for gate check + audit log)
#
# update options:
#   --col inbox|ai|human|gate|done   Move to column
#   --title <text>                   New title
#   --assignee <text>                New assignee
#   --risk 低|中|高                   New risk level
#   --next <text>                    New next action
#   --agent-id <id>                  Acting agent (gate check)
#
# submit options:
#   --escalate "reason"              Escalate to human gate
#   --next-agent <id>                Route to another agent after completion
#   --agent-id <id>                  Acting agent (audit log)
#
# report-test options:
#   --tool tsc|cargo-check|cargo-test|vite-build|custom   Tool name (required)
#   --result pass|fail                                     Test outcome (default: pass)
#   --wi <WI-ID>                                          Link to Work Item
#   --note <text>                                         Extra context (e.g. "0 errors, 12 files")
#
# mail-import options:
#   --from <email>       Sender address (required)
#   --subject <text>     Email subject (required)
#   --snippet <text>     Email body snippet
#   --thread-id <id>     Gmail thread ID (used as sourceRef)
#   --domain <text>      Domain (default: 顧客対応)
#   --ctx <CTX-ID>       Context Card ID to link
#   --risk 低|中|高       Risk level (default: 中)
#
# calendar-import options:
#   --title <text>       Event title (required)
#   --date <datetime>    Event start (ISO 8601)
#   --attendees <text>   Comma-separated attendees
#   --event-id <id>      Calendar event ID (used as sourceRef)
#   --domain <text>      Domain (default: 会議)
#   --ctx <CTX-ID>       Context Card ID to link
#   --wi <WI-ID>         Existing Work Item to annotate (instead of creating new)
#
# sync-github-issues options:
#   --repo <owner/repo>  GitHub repository (default: zyx-corporation/kazane)
#   --project <name>     Kazane project label (default: Kazane)
#   --assignee <name>    Fallback assignee when Issue has none (default: Tomoyuki Kano)
#
# Directory locations (macOS):
#   Tasks:    ~/Library/Application Support/jp.zyxcorp.kazane/tasks/
#   Handoffs: ~/Library/Application Support/jp.zyxcorp.kazane/handoffs/
#   DB:       ~/Library/Application Support/jp.zyxcorp.kazane/kazane.db

set -euo pipefail

BUNDLE_ID="jp.zyxcorp.kazane"

if [[ "$(uname)" == "Darwin" ]]; then
  BASE_DIR="$HOME/Library/Application Support/$BUNDLE_ID"
else
  BASE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/$BUNDLE_ID"
fi

TASKS_DIR="$BASE_DIR/tasks"
HANDOFFS_DIR="$BASE_DIR/handoffs"
DB_PATH="$BASE_DIR/kazane.db"
AGENTD_SOCKET="$BASE_DIR/kazane-agentd.sock"

mkdir -p "$HANDOFFS_DIR"

LOCK_TTL=1800  # 30 minutes stale lock threshold

_lock_path() { echo "$TASKS_DIR/$1.lock"; }

_is_locked() {
  local lock="$(_lock_path "$1")"
  if [ ! -f "$lock" ]; then return 1; fi
  local lock_ts now age
  lock_ts=$(python3 -c "import json,sys; d=json.load(open('$lock')); print(d.get('ts',0))" 2>/dev/null || echo 0)
  now=$(date +%s)
  age=$((now - lock_ts))
  if [ "$age" -gt "$LOCK_TTL" ]; then
    rm -f "$lock"
    return 1
  fi
  return 0
}

_acquire_lock() {
  local wi_id="$1" agent_id="${2:-}"
  local lock="$(_lock_path "$wi_id")"
  python3 -c "
import json, time, os
lock = '$lock'
os.makedirs(os.path.dirname(lock), exist_ok=True)
with open(lock, 'w') as f:
    json.dump({'wi': '$wi_id', 'agent': '$agent_id', 'ts': int(time.time())}, f)
" 2>/dev/null
}

_release_lock() {
  rm -f "$(_lock_path "$1")" 2>/dev/null
}

_check_gate_stops() {
  local agent_id="$1" operation="$2"
  [ -z "$agent_id" ] && return 0
  [ ! -f "$DB_PATH" ] && return 0
  python3 - "$DB_PATH" "$agent_id" "$operation" <<'PYEOF'
import sqlite3, sys
db_path, agent_id, operation = sys.argv[1:4]
con = sqlite3.connect(db_path)
row = con.execute("SELECT gate_stops FROM agent_profiles WHERE id=?", (agent_id,)).fetchone()
con.close()
if not row: sys.exit(0)
for stop in row[0].split("／"):
    stop = stop.strip()
    if stop and stop in operation:
        print(f"Gate stop: '{stop}' は {agent_id} の権限外です", file=__import__('sys').stderr)
        sys.exit(1)
sys.exit(0)
PYEOF
}

_json_field() {
  # Extract a JSON string field using python3
  local file="$1" field="$2"
  python3 -c "
import json, sys
try:
    with open('$file') as f:
        d = json.load(f)
    print(d.get('$field', ''))
except Exception:
    print('')
" 2>/dev/null
}

_json_field_stdin() {
  local field="$1"
  python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d.get('$field', ''))
except Exception:
    print('')
"
}

_pending_tasks() {
  if [ -d "$TASKS_DIR" ]; then
    find "$TASKS_DIR" -maxdepth 1 -name '*.json' 2>/dev/null || true
  fi
}

_submit_handoff() {
  local wi_id="$1" escalate="${2:-false}" escalation_reason="${3:-}" next_agent="${4:-}" agent_id="${5:-}"
  local task_file="$TASKS_DIR/$wi_id.json"

  if [ ! -f "$task_file" ]; then
    echo "Error: task file not found: $task_file" >&2
    exit 1
  fi

  local title domain assignee context_id
  title=$(_json_field "$task_file" "title")
  domain=$(_json_field "$task_file" "domain")
  assignee=$(_json_field "$task_file" "assignee")
  context_id=$(_json_field "$task_file" "contextId")

  local ts ho_id
  ts=$(date -u +%Y%m%d%H%M%S)
  ho_id="HO-$ts-$$"

  python3 - "$HANDOFFS_DIR/$wi_id.json" <<PYEOF
import json, sys, os

wi_id = "$wi_id"
title = "$title"
domain = "$domain"
assignee = "$assignee"
context_id = "$context_id"
escalate = $escalate
escalation_reason = "$escalation_reason"
next_agent = "$next_agent"
agent_id = "$agent_id"
ho_id = "$ho_id"
out_path = sys.argv[1]

ho = {
    "id": ho_id,
    "wi": f"{wi_id} {title}",
    "assignee": assignee,
    "domain": domain,
    "did": "エージェントが指示に従い、関連情報を整理・分析し作業案を作成した。" if not escalate else "エージェントが着手し、責任境界に到達したため停止した。",
    "judged": "責任範囲内で完了と判断した。" if not escalate else "",
    "couldnt": "" if not escalate else (escalation_reason or "責任境界を超えるため判断できなかった。"),
    "uncertain": "詳細は人間が確認を要する可能性あり。" if not escalate else "エスカレーション判断の適切性を人間が確認されたい。",
    "bounce": "" if not escalate else "責任境界を超えるため人間判断へ引き継ぐ。",
    "next": "完了。Evidence Logへの記録を推奨。" if not escalate else "人間が状況を確認し、次アクションを判断する。",
    "updCtx": f"{context_id} を更新予定。" if context_id and context_id != "—" else "",
    "ev": [],
    "gate": "エスカレーション" if escalate else "",
    "ask": "人間が判断・承認をお願いします。" if escalate else "",
    "escalated": escalate,
    "escalationReason": escalation_reason or ("責任境界超過" if escalate else ""),
}

if next_agent:
    ho["nextAgent"] = next_agent
if agent_id:
    ho["agentId"] = agent_id

os.makedirs(os.path.dirname(out_path), exist_ok=True)
with open(out_path, "w", encoding="utf-8") as f:
    json.dump(ho, f, ensure_ascii=False, indent=2)
print(f"Handoff written: {out_path}")
PYEOF
}

cmd="${1:-list}"

case "$cmd" in
  dirs)
    echo "Tasks:    $TASKS_DIR"
    echo "Handoffs: $HANDOFFS_DIR"
    ;;

  list)
    echo "=== Pending agent tasks ==="
    tasks=()
    while IFS= read -r f; do
      [ -n "$f" ] && tasks+=("$f")
    done < <(_pending_tasks)

    if [ ${#tasks[@]} -eq 0 ]; then
      echo "  (no pending tasks)"
    else
      for f in "${tasks[@]}"; do
        wi_id=$(basename "$f" .json)
        title=$(_json_field "$f" "title")
        domain=$(_json_field "$f" "domain")
        risk=$(_json_field "$f" "risk")
        if _is_locked "$wi_id"; then
          lock_agent=$(python3 -c "import json; d=json.load(open('$(_lock_path "$wi_id")')); print(d.get('agent','?'))" 2>/dev/null || echo "?")
          printf "  [%s] %s  domain=%s risk=%s  \033[33m[LOCKED by %s]\033[0m\n" "$wi_id" "$title" "$domain" "$risk" "$lock_agent"
        else
          printf "  [%s] %s  domain=%s risk=%s\n" "$wi_id" "$title" "$domain" "$risk"
        fi
      done
    fi
    ;;

  pickup)
    pu_agent_id=""
    shift
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --agent-id) pu_agent_id="$2"; shift 2 ;;
        *) shift ;;
      esac
    done

    tasks=()
    while IFS= read -r f; do
      [ -n "$f" ] && tasks+=("$f")
    done < <(_pending_tasks)

    if [ ${#tasks[@]} -eq 0 ]; then
      echo "No pending tasks."
      exit 0
    fi
    for f in "${tasks[@]}"; do
      wi_id=$(basename "$f" .json)
      if _is_locked "$wi_id"; then
        lock_agent=$(python3 -c "import json; d=json.load(open('$(_lock_path "$wi_id")')); print(d.get('agent','?'))" 2>/dev/null || echo "?")
        echo "Skipping $wi_id (locked by $lock_agent)" >&2
        continue
      fi
      _acquire_lock "$wi_id" "$pu_agent_id"
      echo ""
      echo "=== Task: $wi_id ==="
      cat "$f"
      echo ""
    done
    ;;

  create)
    # Parse flags
    wi_title=""
    wi_domain="開発"
    wi_assignee="Claude Code"
    wi_ctx="—"
    wi_risk="中"
    wi_next="AIが着手予定"
    wi_agent_id=""
    wi_project=""

    shift
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --title)    wi_title="$2";    shift 2 ;;
        --domain)   wi_domain="$2";   shift 2 ;;
        --assignee) wi_assignee="$2"; shift 2 ;;
        --ctx)      wi_ctx="$2";      shift 2 ;;
        --risk)     wi_risk="$2";     shift 2 ;;
        --next)     wi_next="$2";     shift 2 ;;
        --agent-id) wi_agent_id="$2"; shift 2 ;;
        --project)  wi_project="$2";  shift 2 ;;
        *) echo "Unknown flag: $1" >&2; exit 1 ;;
      esac
    done

    if [ -z "$wi_title" ]; then
      echo "Usage: kazane-agent create --title <title> [--domain <domain>] [--assignee <assignee>] [--ctx <CTX-ID>] [--risk 低|中|高] [--next <nextAction>] [--agent-id <id>] [--project <name>]" >&2
      exit 1
    fi
    [ -n "$wi_agent_id" ] && _check_gate_stops "$wi_agent_id" "create"

    if [ ! -f "$DB_PATH" ]; then
      echo "Error: DB not found at $DB_PATH" >&2
      echo "Launch Kazane once (npm run tauri dev) to initialize the database, then close it and retry." >&2
      exit 1
    fi

    python3 - "$DB_PATH" "$wi_title" "$wi_domain" "$wi_assignee" "$wi_ctx" "$wi_risk" "$wi_next" "$wi_project" <<'PYEOF'
import sqlite3, json, sys, datetime

db_path, title, domain, assignee, ctx_id, risk, next_action, project = sys.argv[1:9]

gate = "AI権限内で着手可" if assignee in ("AI番頭", "AI Assistant", "Claude Code", "Codex", "ローカルLLM") else "人間レビュー待ち"
now = datetime.datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S")

ctx_json = json.dumps({
    "question": "この仕事はなぜ生まれたか（未記入）。",
    "purpose": "目的を記入。",
    "constraint": "制約・責任境界を記入。",
    "unresolved": "未解決点を記入。",
})
ho_json = json.dumps({
    "did": "未着手。", "uncertain": "—", "bounce": "—",
    "next": "担当が着手し、Handoffを残す。",
})

con = sqlite3.connect(db_path)
try:
    # Get next WI id
    rows = con.execute("SELECT id FROM work_items WHERE id LIKE 'WI-%'").fetchall()
    nums = []
    for (r,) in rows:
        try:
            nums.append(int(r.replace("WI-", "")))
        except ValueError:
            pass
    next_num = max(nums, default=0) + 1
    wi_id = f"WI-{next_num:03d}"

    con.execute(
        """INSERT INTO work_items
           (id, title, domain, assignee, col, status, risk, context_id, next_action,
            gate, rde, morning, bounced, gate_perm, gate_stops,
            ctx_json, ho_json, ev_json, github_links_json, project, created_at, updated_at)
           VALUES (?,?,?,?,?,?,?,?,?,?,0,0,0,?,?,?,?,'[]','[]',?,?,?)
           ON CONFLICT(id) DO NOTHING""",
        (wi_id, title, domain, assignee, "inbox", "Inbox", risk, ctx_id, next_action,
         gate, "整理・下調べ・草案", "外部送信／契約／金銭／専門家判断",
         ctx_json, ho_json, project, now, now),
    )
    con.commit()
    print(f"Created: {wi_id} — {title}")
    print(f"  domain={domain}  assignee={assignee}  risk={risk}")
    print(f"  DB: {db_path}")
    print("Kazane will show the new item on next launch (or reload if already open).")
finally:
    con.close()
PYEOF
    ;;

  submit)
    wi_id="${2:-}"
    if [ -z "$wi_id" ]; then
      echo "Usage: kazane-agent submit <WI-ID> [--escalate \"reason\"] [--next-agent <id>] [--agent-id <id>]" >&2
      exit 1
    fi
    sub_escalate="False"
    sub_reason=""
    sub_next_agent=""
    sub_agent_id=""
    shift 2
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --escalate)   sub_escalate="True"; sub_reason="${2:-責任境界を超えるため停止。}"; shift 2 ;;
        --next-agent) sub_next_agent="$2"; shift 2 ;;
        --agent-id)   sub_agent_id="$2";   shift 2 ;;
        *) shift ;;
      esac
    done
    _submit_handoff "$wi_id" "$sub_escalate" "$sub_reason" "$sub_next_agent" "$sub_agent_id"
    _release_lock "$wi_id"
    echo "Kazane will pick up the handoff within 10 seconds."
    ;;

  watch)
    watch_timeout=300
    watch_poll=false
    shift
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --timeout) watch_timeout="$2"; shift 2 ;;
        --poll) watch_poll=true; shift ;;
        *) shift ;;
      esac
    done

    if [ "$watch_poll" = false ] && [ -S "$AGENTD_SOCKET" ]; then
      python3 - "$AGENTD_SOCKET" "$watch_timeout" <<'PYEOF'
import json, socket, sys
socket_path, timeout = sys.argv[1], float(sys.argv[2])
client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
client.settimeout(timeout)
try:
    client.connect(socket_path)
    client.sendall(b'{"type":"subscribe"}\n')
    stream = client.makefile("r", encoding="utf-8")
    ready = json.loads(stream.readline())
    if ready.get("type") != "ready":
        raise RuntimeError("agentd subscription failed")
    event = json.loads(stream.readline())
    if event.get("type") == "task_assigned":
        print(f"New task: {event.get('id', '')}")
        raise SystemExit(0)
    raise RuntimeError(f"unexpected event: {event}")
except TimeoutError:
    print("Timeout: no new tasks arrived.", file=sys.stderr)
    raise SystemExit(1)
finally:
    client.close()
PYEOF
      exit $?
    fi

    echo "Watching for new tasks... (timeout: ${watch_timeout}s)" >&2
    deadline=$(( $(date +%s) + watch_timeout ))
    seen=()
    while IFS= read -r f; do
      [ -n "$f" ] && seen+=("$(basename "$f" .json)")
    done < <(_pending_tasks)

    while true; do
      now=$(date +%s)
      if [ "$now" -ge "$deadline" ]; then
        echo "Timeout: no new tasks arrived." >&2
        exit 1
      fi
      while IFS= read -r f; do
        if [ -n "$f" ]; then
          wi_id=$(basename "$f" .json)
          found=0
          for s in "${seen[@]:-}"; do [ "$s" = "$wi_id" ] && found=1 && break; done
          if [ "$found" -eq 0 ]; then
            echo "New task: $wi_id"
            exit 0
          fi
        fi
      done < <(_pending_tasks)
      sleep 3
    done
    ;;

  lock)
    wi_id="${2:-}"
    lock_agent="${3:-manual}"
    if [ -z "$wi_id" ]; then
      echo "Usage: kazane-agent lock <WI-ID> [agent-id]" >&2; exit 1
    fi
    if _is_locked "$wi_id"; then
      echo "Already locked: $wi_id" >&2; exit 1
    fi
    _acquire_lock "$wi_id" "$lock_agent"
    echo "Locked: $wi_id (agent=$lock_agent)"
    ;;

  unlock)
    wi_id="${2:-}"
    if [ -z "$wi_id" ]; then
      echo "Usage: kazane-agent unlock <WI-ID>" >&2; exit 1
    fi
    _release_lock "$wi_id"
    echo "Unlocked: $wi_id"
    ;;

  auto)
    tasks=()
    while IFS= read -r f; do
      [ -n "$f" ] && tasks+=("$f")
    done < <(_pending_tasks)

    if [ ${#tasks[@]} -eq 0 ]; then
      echo "No pending tasks."
      exit 0
    fi
    echo "Auto-processing ${#tasks[@]} task(s)..."
    for f in "${tasks[@]}"; do
      wi_id=$(basename "$f" .json)
      echo "  Processing: $wi_id"
      _submit_handoff "$wi_id" "False" ""
    done
    echo "Done. Kazane will pick up handoffs within 10 seconds."
    ;;

  read)
    wi_id="${2:-}"
    if [ -z "$wi_id" ]; then
      echo "Usage: kazane-agent read <WI-ID>" >&2
      exit 1
    fi
    if [ ! -f "$DB_PATH" ]; then
      echo "Error: DB not found at $DB_PATH" >&2; exit 1
    fi
    python3 - "$DB_PATH" "$wi_id" <<'PYEOF'
import sqlite3, json, sys
db_path, wi_id = sys.argv[1], sys.argv[2]
con = sqlite3.connect(db_path)
con.row_factory = sqlite3.Row
row = con.execute("SELECT * FROM work_items WHERE id=?", (wi_id,)).fetchone()
if not row:
    print(f"Not found: {wi_id}", file=sys.stderr)
    sys.exit(1)
d = dict(row)
for k in ("ctx_json","ho_json","ev_json","rde_audit_json","github_links_json"):
    if d.get(k):
        d[k] = json.loads(d[k])
print(json.dumps(d, ensure_ascii=False, indent=2))
con.close()
PYEOF
    ;;

  update)
    wi_id="${2:-}"
    if [ -z "$wi_id" ]; then
      echo "Usage: kazane-agent update <WI-ID> [--col <col>] [--title <text>] [--assignee <text>] [--risk 低|中|高] [--next <text>]" >&2
      exit 1
    fi
    if [ ! -f "$DB_PATH" ]; then
      echo "Error: DB not found at $DB_PATH" >&2; exit 1
    fi

    shift 2
    upd_col="" upd_title="" upd_assignee="" upd_risk="" upd_next="" upd_agent_id="" upd_project=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --col)      upd_col="$2";      shift 2 ;;
        --title)    upd_title="$2";    shift 2 ;;
        --assignee) upd_assignee="$2"; shift 2 ;;
        --risk)     upd_risk="$2";     shift 2 ;;
        --next)     upd_next="$2";     shift 2 ;;
        --agent-id) upd_agent_id="$2"; shift 2 ;;
        --project)  upd_project="$2";  shift 2 ;;
        *) echo "Unknown flag: $1" >&2; exit 1 ;;
      esac
    done
    [ -n "$upd_agent_id" ] && _check_gate_stops "$upd_agent_id" "update"

    python3 - "$DB_PATH" "$wi_id" "$upd_col" "$upd_title" "$upd_assignee" "$upd_risk" "$upd_next" "$upd_project" <<'PYEOF'
import sqlite3, json, sys, datetime

db_path, wi_id, col, title, assignee, risk, next_action, project = sys.argv[1:9]

COL_STATUS = {
    "inbox": "Inbox", "ai": "AI Working",
    "human": "Needs Human", "gate": "Expert / Gate", "done": "Done / Logged",
}
now = datetime.datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S")
sets, vals = [], []
if col:
    sets += ["col=?", "status=?"]; vals += [col, COL_STATUS.get(col, col)]
if title:
    sets += ["title=?"]; vals.append(title)
if assignee:
    sets += ["assignee=?"]; vals.append(assignee)
if risk:
    sets += ["risk=?"]; vals.append(risk)
if next_action:
    sets += ["next_action=?"]; vals.append(next_action)
if project:
    sets += ["project=?"]; vals.append(project)

if not sets:
    print("Nothing to update — specify at least one flag.", file=sys.stderr)
    sys.exit(1)

sets.append("updated_at=?"); vals.append(now)
vals.append(wi_id)
con = sqlite3.connect(db_path)
cur = con.execute(f"UPDATE work_items SET {', '.join(sets)} WHERE id=?", vals)
con.commit()
if cur.rowcount == 0:
    print(f"Not found: {wi_id}", file=sys.stderr); sys.exit(1)
print(f"Updated: {wi_id}")
for f, v in zip(["col","title","assignee","risk","next","project"], [col,title,assignee,risk,next_action,project]):
    if v: print(f"  {f} → {v}")
con.close()
PYEOF
    ;;

  status)
    if [ ! -f "$DB_PATH" ]; then
      echo "DB not found. Launch Kazane once to initialize." >&2; exit 1
    fi
    python3 - "$DB_PATH" <<'PYEOF'
import sqlite3, json, sys
con = sqlite3.connect(sys.argv[1])
con.row_factory = sqlite3.Row

items = con.execute("SELECT id,title,domain,assignee,col,risk,next_action FROM work_items ORDER BY col,domain").fetchall()
handoffs = con.execute("SELECT COUNT(*) FROM handoff_notes").fetchone()[0]
evidence = con.execute("SELECT COUNT(*) FROM evidence_log").fetchone()[0]
ctx_count = con.execute("SELECT COUNT(*) FROM context_cards").fetchone()[0]

COL_ORDER = ["inbox","ai","human","gate","done"]
by_col = {c: [] for c in COL_ORDER}
for r in items:
    by_col.setdefault(r["col"], []).append(r)

print(f"=== Kazane Status ===")
print(f"  Work Items:    {len(items)}  (HandoffNotes: {handoffs}  Evidence: {evidence}  ContextCards: {ctx_count})")
print()
for col in COL_ORDER:
    rows = by_col.get(col, [])
    if not rows: continue
    col_names = {"inbox":"Inbox","ai":"AI Working","human":"Needs Human","gate":"Expert/Gate","done":"Done/Logged"}
    print(f"  [{col_names.get(col,col)}] ({len(rows)})")
    for r in rows:
        risk_mark = "!" if r["risk"]=="高" else "·"
        print(f"    {risk_mark} {r['id']:8s}  [{r['domain']:6s}] {r['title'][:60]}")
    print()
con.close()
