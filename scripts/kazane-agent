#!/usr/bin/env bash
# kazane-agent — Agent CLI for Kazane Work OS (v0.4 michi)
#
# Reads Work Items from the Kazane task queue and writes back Handoff Notes.
# Kazane polls the handoffs directory every 10s and auto-imports results.
#
# Usage:
#   kazane-agent list                          — list pending tasks
#   kazane-agent pickup                        — print task JSON for each pending item
#   kazane-agent status                        — project overview (all items by column)
#   kazane-agent read <WI-ID>                  — print full Work Item as JSON
#   kazane-agent create --title <title> [opts] — create a new Work Item in SQLite
#   kazane-agent update <WI-ID> [opts]         — patch fields on an existing Work Item
#   kazane-agent report-test --tool <tool> [opts] — record test result as Evidence Log entry
#   kazane-agent submit <WI-ID>                — submit a completed handoff
#   kazane-agent submit <WI-ID> --escalate "reason"  — submit with escalation
#   kazane-agent auto                          — auto-process all pending tasks (demo)
#   kazane-agent dirs                          — print task/handoff directory paths
#
# create options:
#   --title <text>       Work item title (required)
#   --domain <text>      Domain (default: 開発)
#   --assignee <text>    Assignee (default: Claude Code)
#   --ctx <CTX-ID>       Context Card ID (default: —)
#   --risk 低|中|高       Risk level (default: 中)
#   --next <text>        Next action text
#
# update options:
#   --col inbox|ai|human|gate|done   Move to column
#   --title <text>                   New title
#   --assignee <text>                New assignee
#   --risk 低|中|高                   New risk level
#   --next <text>                    New next action
#
# report-test options:
#   --tool tsc|cargo-check|cargo-test|vite-build|custom   Tool name (required)
#   --result pass|fail                                     Test outcome (default: pass)
#   --wi <WI-ID>                                          Link to Work Item
#   --note <text>                                         Extra context (e.g. "0 errors, 12 files")
#
# Directory locations (macOS):
#   Tasks:    ~/Library/Application Support/jp.zyxcorp.kazane/tasks/
#   Handoffs: ~/Library/Application Support/jp.zyxcorp.kazane/handoffs/
#   DB:       ~/Library/Application Support/jp.zyxcorp.kazane/kazane.db

set -euo pipefail

BUNDLE_ID="jp.zyxcorp.kazane"

if [[ "$(uname)" == "Darwin" ]]; then
  BASE_DIR="$HOME/Library/Application Support/$BUNDLE_ID"
else
  BASE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/$BUNDLE_ID"
fi

TASKS_DIR="$BASE_DIR/tasks"
HANDOFFS_DIR="$BASE_DIR/handoffs"
DB_PATH="$BASE_DIR/kazane.db"

mkdir -p "$HANDOFFS_DIR"

_json_field() {
  # Extract a JSON string field using python3
  local file="$1" field="$2"
  python3 -c "
import json, sys
try:
    with open('$file') as f:
        d = json.load(f)
    print(d.get('$field', ''))
except Exception:
    print('')
" 2>/dev/null
}

_json_field_stdin() {
  local field="$1"
  python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d.get('$field', ''))
except Exception:
    print('')
"
}

_pending_tasks() {
  if [ -d "$TASKS_DIR" ]; then
    find "$TASKS_DIR" -maxdepth 1 -name '*.json' 2>/dev/null || true
  fi
}

_submit_handoff() {
  local wi_id="$1" escalate="${2:-false}" escalation_reason="${3:-}"
  local task_file="$TASKS_DIR/$wi_id.json"

  if [ ! -f "$task_file" ]; then
    echo "Error: task file not found: $task_file" >&2
    exit 1
  fi

  local title domain assignee context_id
  title=$(_json_field "$task_file" "title")
  domain=$(_json_field "$task_file" "domain")
  assignee=$(_json_field "$task_file" "assignee")
  context_id=$(_json_field "$task_file" "contextId")

  local ts ho_id
  ts=$(date +%s)
  ho_id="HO-$(echo "$ts" | tail -c 5 | sed 's/^0*//')"

  python3 - "$HANDOFFS_DIR/$wi_id.json" <<PYEOF
import json, sys, os

wi_id = "$wi_id"
title = "$title"
domain = "$domain"
assignee = "$assignee"
context_id = "$context_id"
escalate = $escalate
escalation_reason = "$escalation_reason"
ho_id = "$ho_id"
out_path = sys.argv[1]

ho = {
    "id": ho_id,
    "wi": f"{wi_id} {title}",
    "assignee": assignee,
    "domain": domain,
    "did": "エージェントが指示に従い、関連情報を整理・分析し作業案を作成した。" if not escalate else "エージェントが着手し、責任境界に到達したため停止した。",
    "judged": "責任範囲内で完了と判断した。" if not escalate else "",
    "couldnt": "" if not escalate else (escalation_reason or "責任境界を超えるため判断できなかった。"),
    "uncertain": "詳細は人間が確認を要する可能性あり。" if not escalate else "エスカレーション判断の適切性を人間が確認されたい。",
    "bounce": "" if not escalate else "責任境界を超えるため人間判断へ引き継ぐ。",
    "next": "完了。Evidence Logへの記録を推奨。" if not escalate else "人間が状況を確認し、次アクションを判断する。",
    "updCtx": f"{context_id} を更新予定。" if context_id and context_id != "—" else "",
    "ev": [],
    "gate": "エスカレーション" if escalate else "",
    "ask": "人間が判断・承認をお願いします。" if escalate else "",
    "escalated": escalate,
    "escalationReason": escalation_reason or ("責任境界超過" if escalate else ""),
}

os.makedirs(os.path.dirname(out_path), exist_ok=True)
with open(out_path, "w", encoding="utf-8") as f:
    json.dump(ho, f, ensure_ascii=False, indent=2)
print(f"Handoff written: {out_path}")
PYEOF
}

cmd="${1:-list}"

case "$cmd" in
  dirs)
    echo "Tasks:    $TASKS_DIR"
    echo "Handoffs: $HANDOFFS_DIR"
    ;;

  list)
    echo "=== Pending agent tasks ==="
    tasks=()
    while IFS= read -r f; do
      [ -n "$f" ] && tasks+=("$f")
    done < <(_pending_tasks)

    if [ ${#tasks[@]} -eq 0 ]; then
      echo "  (no pending tasks)"
    else
      for f in "${tasks[@]}"; do
        wi_id=$(basename "$f" .json)
        title=$(_json_field "$f" "title")
        domain=$(_json_field "$f" "domain")
        risk=$(_json_field "$f" "risk")
        printf "  [%s] %s  domain=%s risk=%s\n" "$wi_id" "$title" "$domain" "$risk"
      done
    fi
    ;;

  pickup)
    tasks=()
    while IFS= read -r f; do
      [ -n "$f" ] && tasks+=("$f")
    done < <(_pending_tasks)

    if [ ${#tasks[@]} -eq 0 ]; then
      echo "No pending tasks."
      exit 0
    fi
    for f in "${tasks[@]}"; do
      wi_id=$(basename "$f" .json)
      echo ""
      echo "=== Task: $wi_id ==="
      cat "$f"
      echo ""
    done
    ;;

  create)
    # Parse flags
    wi_title=""
    wi_domain="開発"
    wi_assignee="Claude Code"
    wi_ctx="—"
    wi_risk="中"
    wi_next="AIが着手予定"

    shift
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --title)    wi_title="$2";    shift 2 ;;
        --domain)   wi_domain="$2";   shift 2 ;;
        --assignee) wi_assignee="$2"; shift 2 ;;
        --ctx)      wi_ctx="$2";      shift 2 ;;
        --risk)     wi_risk="$2";     shift 2 ;;
        --next)     wi_next="$2";     shift 2 ;;
        *) echo "Unknown flag: $1" >&2; exit 1 ;;
      esac
    done

    if [ -z "$wi_title" ]; then
      echo "Usage: kazane-agent create --title <title> [--domain <domain>] [--assignee <assignee>] [--ctx <CTX-ID>] [--risk 低|中|高] [--next <nextAction>]" >&2
      exit 1
    fi

    if [ ! -f "$DB_PATH" ]; then
      echo "Error: DB not found at $DB_PATH" >&2
      echo "Launch Kazane once (npm run tauri dev) to initialize the database, then close it and retry." >&2
      exit 1
    fi

    python3 - "$DB_PATH" "$wi_title" "$wi_domain" "$wi_assignee" "$wi_ctx" "$wi_risk" "$wi_next" <<'PYEOF'
import sqlite3, json, sys, datetime

db_path, title, domain, assignee, ctx_id, risk, next_action = sys.argv[1:8]

gate = "AI権限内で着手可" if assignee in ("AI番頭", "AI Assistant", "Claude Code", "Codex", "ローカルLLM") else "人間レビュー待ち"
now = datetime.datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S")

ctx_json = json.dumps({
    "question": "この仕事はなぜ生まれたか（未記入）。",
    "purpose": "目的を記入。",
    "constraint": "制約・責任境界を記入。",
    "unresolved": "未解決点を記入。",
})
ho_json = json.dumps({
    "did": "未着手。", "uncertain": "—", "bounce": "—",
    "next": "担当が着手し、Handoffを残す。",
})

con = sqlite3.connect(db_path)
try:
    # Get next WI id
    rows = con.execute("SELECT id FROM work_items WHERE id LIKE 'WI-%'").fetchall()
    nums = []
    for (r,) in rows:
        try:
            nums.append(int(r.replace("WI-", "")))
        except ValueError:
            pass
    next_num = max(nums, default=0) + 1
    wi_id = f"WI-{next_num:03d}"

    con.execute(
        """INSERT INTO work_items
           (id, title, domain, assignee, col, status, risk, context_id, next_action,
            gate, rde, morning, bounced, gate_perm, gate_stops,
            ctx_json, ho_json, ev_json, github_links_json, created_at, updated_at)
           VALUES (?,?,?,?,?,?,?,?,?,?,0,0,0,?,?,?,?,'[]','[]',?,?)
           ON CONFLICT(id) DO NOTHING""",
        (wi_id, title, domain, assignee, "inbox", "Inbox", risk, ctx_id, next_action,
         gate, "整理・下調べ・草案", "外部送信／契約／金銭／専門家判断",
         ctx_json, ho_json, now, now),
    )
    con.commit()
    print(f"Created: {wi_id} — {title}")
    print(f"  domain={domain}  assignee={assignee}  risk={risk}")
    print(f"  DB: {db_path}")
    print("Kazane will show the new item on next launch (or reload if already open).")
finally:
    con.close()
PYEOF
    ;;

  submit)
    wi_id="${2:-}"
    if [ -z "$wi_id" ]; then
      echo "Usage: kazane-agent submit <WI-ID> [--escalate \"reason\"]" >&2
      exit 1
    fi
    if [ "${3:-}" = "--escalate" ]; then
      reason="${4:-責任境界を超えるため停止。}"
      _submit_handoff "$wi_id" "True" "$reason"
    else
      _submit_handoff "$wi_id" "False" ""
    fi
    echo "Kazane will pick up the handoff within 10 seconds."
    ;;

  auto)
    tasks=()
    while IFS= read -r f; do
      [ -n "$f" ] && tasks+=("$f")
    done < <(_pending_tasks)

    if [ ${#tasks[@]} -eq 0 ]; then
      echo "No pending tasks."
      exit 0
    fi
    echo "Auto-processing ${#tasks[@]} task(s)..."
    for f in "${tasks[@]}"; do
      wi_id=$(basename "$f" .json)
      echo "  Processing: $wi_id"
      _submit_handoff "$wi_id" "False" ""
    done
    echo "Done. Kazane will pick up handoffs within 10 seconds."
    ;;

  read)
    wi_id="${2:-}"
    if [ -z "$wi_id" ]; then
      echo "Usage: kazane-agent read <WI-ID>" >&2
      exit 1
    fi
    if [ ! -f "$DB_PATH" ]; then
      echo "Error: DB not found at $DB_PATH" >&2; exit 1
    fi
    python3 - "$DB_PATH" "$wi_id" <<'PYEOF'
import sqlite3, json, sys
db_path, wi_id = sys.argv[1], sys.argv[2]
con = sqlite3.connect(db_path)
con.row_factory = sqlite3.Row
row = con.execute("SELECT * FROM work_items WHERE id=?", (wi_id,)).fetchone()
if not row:
    print(f"Not found: {wi_id}", file=sys.stderr)
    sys.exit(1)
d = dict(row)
for k in ("ctx_json","ho_json","ev_json","rde_audit_json","github_links_json"):
    if d.get(k):
        d[k] = json.loads(d[k])
print(json.dumps(d, ensure_ascii=False, indent=2))
con.close()
PYEOF
    ;;

  update)
    wi_id="${2:-}"
    if [ -z "$wi_id" ]; then
      echo "Usage: kazane-agent update <WI-ID> [--col <col>] [--title <text>] [--assignee <text>] [--risk 低|中|高] [--next <text>]" >&2
      exit 1
    fi
    if [ ! -f "$DB_PATH" ]; then
      echo "Error: DB not found at $DB_PATH" >&2; exit 1
    fi

    shift 2
    upd_col="" upd_title="" upd_assignee="" upd_risk="" upd_next=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --col)      upd_col="$2";      shift 2 ;;
        --title)    upd_title="$2";    shift 2 ;;
        --assignee) upd_assignee="$2"; shift 2 ;;
        --risk)     upd_risk="$2";     shift 2 ;;
        --next)     upd_next="$2";     shift 2 ;;
        *) echo "Unknown flag: $1" >&2; exit 1 ;;
      esac
    done

    python3 - "$DB_PATH" "$wi_id" "$upd_col" "$upd_title" "$upd_assignee" "$upd_risk" "$upd_next" <<'PYEOF'
import sqlite3, json, sys, datetime

db_path, wi_id, col, title, assignee, risk, next_action = sys.argv[1:8]

COL_STATUS = {
    "inbox": "Inbox", "ai": "AI Working",
    "human": "Needs Human", "gate": "Expert / Gate", "done": "Done / Logged",
}
now = datetime.datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S")
sets, vals = [], []
if col:
    sets += ["col=?", "status=?"]; vals += [col, COL_STATUS.get(col, col)]
if title:
    sets += ["title=?"]; vals.append(title)
if assignee:
    sets += ["assignee=?"]; vals.append(assignee)
if risk:
    sets += ["risk=?"]; vals.append(risk)
if next_action:
    sets += ["next_action=?"]; vals.append(next_action)

if not sets:
    print("Nothing to update — specify at least one flag.", file=sys.stderr)
    sys.exit(1)

sets.append("updated_at=?"); vals.append(now)
vals.append(wi_id)
con = sqlite3.connect(db_path)
cur = con.execute(f"UPDATE work_items SET {', '.join(sets)} WHERE id=?", vals)
con.commit()
if cur.rowcount == 0:
    print(f"Not found: {wi_id}", file=sys.stderr); sys.exit(1)
print(f"Updated: {wi_id}")
for f, v in zip(["col","title","assignee","risk","next"], [col,title,assignee,risk,next_action]):
    if v: print(f"  {f} → {v}")
con.close()
PYEOF
    ;;

  status)
    if [ ! -f "$DB_PATH" ]; then
      echo "DB not found. Launch Kazane once to initialize." >&2; exit 1
    fi
    python3 - "$DB_PATH" <<'PYEOF'
import sqlite3, json, sys
con = sqlite3.connect(sys.argv[1])
con.row_factory = sqlite3.Row

items = con.execute("SELECT id,title,domain,assignee,col,risk,next_action FROM work_items ORDER BY col,domain").fetchall()
handoffs = con.execute("SELECT COUNT(*) FROM handoff_notes").fetchone()[0]
evidence = con.execute("SELECT COUNT(*) FROM evidence_log").fetchone()[0]
ctx_count = con.execute("SELECT COUNT(*) FROM context_cards").fetchone()[0]

COL_ORDER = ["inbox","ai","human","gate","done"]
by_col = {c: [] for c in COL_ORDER}
for r in items:
    by_col.setdefault(r["col"], []).append(r)

print(f"=== Kazane Status ===")
print(f"  Work Items:    {len(items)}  (HandoffNotes: {handoffs}  Evidence: {evidence}  ContextCards: {ctx_count})")
print()
for col in COL_ORDER:
    rows = by_col.get(col, [])
    if not rows: continue
    col_names = {"inbox":"Inbox","ai":"AI Working","human":"Needs Human","gate":"Expert/Gate","done":"Done/Logged"}
    print(f"  [{col_names.get(col,col)}] ({len(rows)})")
    for r in rows:
        risk_mark = "!" if r["risk"]=="高" else "·"
        print(f"    {risk_mark} {r['id']:8s}  [{r['domain']:6s}] {r['title'][:60]}")
    print()
con.close()
PYEOF
    ;;

  report-test)
    rt_tool=""
    rt_result="pass"
    rt_wi=""
    rt_note=""

    shift
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --tool)   rt_tool="$2";   shift 2 ;;
        --result) rt_result="$2"; shift 2 ;;
        --wi)     rt_wi="$2";     shift 2 ;;
        --note)   rt_note="$2";   shift 2 ;;
        *) echo "Unknown flag: $1" >&2; exit 1 ;;
      esac
    done

    if [ -z "$rt_tool" ]; then
      echo "Usage: kazane-agent report-test --tool <tsc|cargo-check|cargo-test|vite-build|custom> [--result pass|fail] [--wi <WI-ID>] [--note <text>]" >&2
      exit 1
    fi
    if [ ! -f "$DB_PATH" ]; then
      echo "Error: DB not found at $DB_PATH" >&2; exit 1
    fi

    python3 - "$DB_PATH" "$rt_tool" "$rt_result" "$rt_wi" "$rt_note" <<'PYEOF'
import sqlite3, json, sys, datetime, uuid

db_path, tool, result, wi_id, note = sys.argv[1:6]

trust = "高" if result == "pass" else "低"
outcome = "✓ pass" if result == "pass" else "✗ fail"
label = f"{tool}: {outcome}"
ev_id = "EV-" + datetime.datetime.utcnow().strftime("%Y%m%d%H%M%S")
now = datetime.datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S")

# Try to get current git SHA for store reference
import subprocess
try:
    sha = subprocess.check_output(["git", "rev-parse", "--short", "HEAD"], stderr=subprocess.DEVNULL).decode().strip()
    store = f"local:git:{sha}"
except Exception:
    store = "local"

con = sqlite3.connect(db_path)
con.execute(
    """INSERT OR IGNORE INTO evidence_log
       (id, type, label, trust, store, wi_id, ho_id, ctx_id, note, created_at)
       VALUES (?,?,?,?,?,?,?,?,?,?)""",
    (ev_id, tool, label, trust, store, wi_id or "", "", "", note or "", now),
)
con.commit()
print(f"Evidence recorded: {ev_id}")
print(f"  tool={tool}  result={result}  trust={trust}")
if wi_id: print(f"  linked to: {wi_id}")
print(f"  store: {store}")
con.close()
PYEOF
    ;;

  help|--help|-h)
    grep '^#' "$0" | sed 's/^# \{0,1\}//' | tail -n +2
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    echo "Run 'kazane-agent help' for usage." >&2
    exit 1
    ;;
esac
